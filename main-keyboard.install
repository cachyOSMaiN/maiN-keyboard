post_install() {
    echo ""
    echo "==> MaiN_Keyboard installed!"
    echo ""
    echo "==> To use MaiN_Keyboard, add your user to the 'input' group:"
    echo "      sudo usermod -aG input \$USER"
    echo ""
    echo "==> Then log out and log back in."
    echo ""
    echo "==> Start with: main-keyboard"
    echo ""
}

post_upgrade() {
    post_install
}
